{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Starrise AI",
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png"
  },
  "colors": {
    "primary": "#0284c7",
    "light": "#f0f9ff",
    "dark": "#082f49"
  },
  "variables": {
    "api-base-url": "https://ai.starrise.tech/v1",
    "api-origin": "https://ai.starrise.tech",
    "ws-base-url": "wss://ai.starrise.tech"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": false,
        "pages": [
          "en/overview"
        ],
        "groups": [
          {
            "group": "Guide",
            "pages": [
              "en/guide/quick-start",
              "en/guide/authentication",
              "en/guide/client-compatibility"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "en/api/models",
              "en/api/chat",
              "en/api/responses",
              "en/api/claude",
              "en/api/gemini",
              "en/api/embeddings",
              "en/api/images",
              "en/api/video",
              "en/api/audio",
              "en/api/realtime",
              "en/api/midjourney",
              "en/api/suno"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "en/guide/faq",
              "en/guide/payment"
            ]
          }
        ]
      },
      {
        "language": "zh",
        "pages": [
          "zh/overview"
        ],
        "groups": [
          {
            "group": "指南",
            "pages": [
              "zh/guide/quick-start",
              "zh/guide/authentication",
              "zh/guide/client-compatibility"
            ]
          },
          {
            "group": "API 参考",
            "pages": [
              "zh/api/models",
              "zh/api/chat",
              "zh/api/responses",
              "zh/api/claude",
              "zh/api/gemini",
              "zh/api/embeddings",
              "zh/api/images",
              "zh/api/video",
              "zh/api/audio",
              "zh/api/realtime",
              "zh/api/midjourney",
              "zh/api/suno"
            ]
          },
          {
            "group": "资源",
            "pages": [
              "zh/guide/faq",
              "zh/guide/payment"
            ]
          }
        ],
        "default": true
      }
    ]
  }
}
